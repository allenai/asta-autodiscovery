# .dockerignore - Used by api/Dockerfile and scripts/Dockerfile
# Note: Must work for both the API build and maintenance scripts build

# Ignore common development files
.git
.github
.venv
.pytest_cache
.ruff_cache
.vscode
.claude
**/__pycache__
**/*.pyc
**/.DS_Store

# Ignore other service directories
ui
proxy
sonar
autods-viz
devtools
docs

# Ignore markdown and config files
*.md
.gitignore
.envrc
justfile
mkdocs.yml
ruff.toml
docker-compose.yaml
mcpdoc.json

# Keep what we need
!packages/
!api/
!scripts/
!pyproject.toml
!uv.lock
