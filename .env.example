# INSTRUCTIONS
#
# - Copy this file into /.env
# - Get keys from 1Password or Google Cloud Console

GOOGLE_ACCESS_KEY_ID=GOOG1E...
GOOGLE_ACCESS_KEY_SECRET=...
GOOGLE_APPLICATION_CREDENTIALS=./secrets/gcp-key.json  # Need to make a secure directory and place your GCP key file here

GCS_BUCKET=autodiscovery
GCP_PROJECT=example-gcp-project

MODAL_TOKEN_ID=...
MODAL_TOKEN_SECRET=...
MODAL_IMAGE_BUILDER_VERSION=2025.06
MODAL_ENVIRONMENT=AutoDiscovery

OPENAI_API_KEY=...

VERTEX_PROJECT_ID=example-gcp-project
VERTEX_LOCATION=global

# LLM retry/backoff configuration
LLM_RETRY_MAX_RETRIES=5
LLM_RETRY_INITIAL_DELAY_SECONDS=1.0
LLM_RETRY_MAX_DELAY_SECONDS=20.0

# For email job to lookup user emails
AUTH0_MGMT_CLIENT_ID=
AUTH0_MGMT_CLIENT_SECRET=

# SMTP server used by the completion-email job. Defaults are placeholders;
# set these to your mail relay in deployment.
SMTP_SERVER=smtp.example.com
SMTP_PORT=25
SENDER_EMAIL=no-reply@example.com

# UI (build-time): GCS bucket hosting the preloaded sample datasets shown in the
# new-run flow. Leave unset to show the placeholder bucket.
NEXT_PUBLIC_PRELOADED_DATASET_BUCKET=your-dataset-bucket

# Optional: Required Auth0 permission for authenticated users to access the API.
# If not set or empty, any authenticated user can access the system.
# Example: AUTH0_REQUIRED_PERMISSION=enroll:autodiscovery_v0
# AUTH0_REQUIRED_PERMISSION=

# If set, forces the application to masquerade as the specified user for development purposes.
# Typically looks something like "google-oauth2|111...475". You can find it in the auth0 user management dashboard.
DEV_MASQUERADE_USER
