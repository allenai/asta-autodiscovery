# INSTRUCTIONS
#
# - Copy this file into /.env
# - Get keys from 1Password or Google Cloud Console

GOOGLE_ACCESS_KEY_ID=GOOG1E...
GOOGLE_ACCESS_KEY_SECRET=...
GOOGLE_APPLICATION_CREDENTIALS=./secrets/gcp-key.json  # Need to make a secure directory and place your GCP key file here

GCS_BUCKET=autodiscovery
GCP_PROJECT=example-gcp-project

MODAL_TOKEN_ID=...
MODAL_TOKEN_SECRET=...
MODAL_IMAGE_BUILDER_VERSION=2025.06
MODAL_ENVIRONMENT=AutoDiscovery

OPENAI_API_KEY=...

VERTEX_PROJECT_ID=example-gcp-project
VERTEX_LOCATION=global

# LLM retry/backoff configuration
LLM_RETRY_MAX_RETRIES=5
LLM_RETRY_INITIAL_DELAY_SECONDS=1.0
LLM_RETRY_MAX_DELAY_SECONDS=20.0

# Asta context service (artifact storage + metadata).
ASTA_CONTEXT_SERVICE_URL=
ASTA_CONTEXT_SERVICE_API_KEY=

# For email job to lookup user emails
AUTH0_MGMT_DOMAIN=
AUTH0_MGMT_CLIENT_ID=
AUTH0_MGMT_CLIENT_SECRET=

# Email job: mail server and from-address (required to send; port defaults to 25)
SMTP_SERVER=
SENDER_EMAIL=
# SMTP_PORT=25

# ===========================================================================
# Authentication provider (swappable). See docs/design/auth-providers.md.
# ===========================================================================
# Which provider to activate: auth0 (default) | password_file | none
AUTH_PROVIDER=auth0

# --- auth0 provider ---
# AUTH0_DOMAIN and AUTH0_AUDIENCE configure JWT validation (see docker-compose).
# AUTH0_CLIENT_ID is served to the UI via /api/auth/config (runtime SPA config).
AUTH0_CLIENT_ID=

# --- password_file provider ---
# Path to the mounted user store (administered with api/scripts/auth_admin.py).
# AUTH_PASSWORD_FILE=/secrets/users.json
# Secret used to sign HS256 session tokens. Use a long random value (>= 32 bytes).
# AUTH_SESSION_SECRET=
# Optional session lifetime in seconds (default 43200 = 12h).
# AUTH_SESSION_TTL=43200

# --- none provider (desktop mode) ---
# No configuration: every request is a fixed "local" user with all permissions.

# Optional: Required permission for authenticated users to access the API.
# If not set or empty, any authenticated user can access the system.
# Falls back to AUTH0_REQUIRED_PERMISSION for backward compatibility.
# Example: AUTH_REQUIRED_PERMISSION=enroll:autodiscovery_v0
# AUTH_REQUIRED_PERMISSION=
# AUTH0_REQUIRED_PERMISSION=
